<Window x:Class="IBIMCA.UI.UpdateExternalDBWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM 친환경 정보 연계 결과"
        Height="600" Width="1360"
        MinHeight="560" MinWidth="1180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F8FC">

    <Window.Resources>
        <SolidColorBrush x:Key="BrandBlue" Color="#0B3A78"/>
        <SolidColorBrush x:Key="DeepBlue" Color="#0B3A78"/>
        <SolidColorBrush x:Key="SoftBlue" Color="#EAF3FF"/>
        <SolidColorBrush x:Key="Line" Color="#D8E2F0"/>
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MutedText" Color="#64748B"/>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SmallBadgeButton" TargetType="Button">
            <Setter Property="Height" Value="22"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="#EAF8E7"/>
            <Setter Property="BorderBrush" Value="#B9E1B0"/>
            <Setter Property="Foreground" Value="#287D35"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="FilterCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,5,18,5"/>
            <Setter Property="Foreground" Value="#0F2544"/>
            <Setter Property="IsChecked" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#F1F6FD"/>
            <Setter Property="Foreground" Value="#0F2544"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#D8E2F0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#E3EAF3"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="검색 및 필터" FontSize="15" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,18"/>

                        <TextBlock Text="프로젝트:" FontWeight="SemiBold" Foreground="#334155"/>
                        <ComboBox Height="30" SelectedIndex="0" Margin="0,6,0,12">
                            <ComboBoxItem Content="프로젝트1"/>
                            <ComboBoxItem Content="프로젝트2"/>
                        </ComboBox>

                        <TextBlock Text="대상 모델:" FontWeight="SemiBold" Foreground="#334155"/>
                        <ComboBox Height="30" SelectedIndex="0" Margin="0,6,0,12">
                            <ComboBoxItem Content="친환경 검토 대상"/>
                            <ComboBoxItem Content="전체 BIM 요소"/>
                        </ComboBox>

                        <TextBox Height="32"
                                 Padding="10,0"
                                 VerticalContentAlignment="Center"
                                 Text="자재명 / 제품명 / 제조사 검색"
                                 Foreground="#8A98AA"
                                 Margin="0,0,0,12"/>

                        <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="인증구분" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <CheckBox Content="환경성적표지" Style="{StaticResource FilterCheckBox}"/>
                                    <CheckBox Content="저탄소제품" Style="{StaticResource FilterCheckBox}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="매칭상태" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <CheckBox Content="자동 매칭" Style="{StaticResource FilterCheckBox}"/>
                                    <CheckBox Content="검토 필요" Style="{StaticResource FilterCheckBox}"/>
                                    <CheckBox Content="미등록" Style="{StaticResource FilterCheckBox}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Padding="10">
                            <StackPanel>
                                <TextBlock Text="활용항목" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,6"/>
                                <WrapPanel>
                                    <CheckBox Content="GB 평가" Style="{StaticResource FilterCheckBox}"/>
                                    <CheckBox Content="탄소발자국" Style="{StaticResource FilterCheckBox}"/>
                                    <CheckBox Content="색상 가시화" Style="{StaticResource FilterCheckBox}"/>
                                    <CheckBox Content="보고서 출력" Style="{StaticResource FilterCheckBox}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="필터 적용" Style="{StaticResource PrimaryButton}" Command="{Binding ApplyFilterCommand}"/>
                        <Button Grid.Column="2" Content="초기화" Style="{StaticResource OutlineButton}" Command="{Binding ResetFilterCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="48"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="BIM 요소-친환경 제품 매칭 목록" FontSize="15" FontWeight="Bold" Foreground="#0F2544" Margin="0,2,0,10"/>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,32,0,10">
                    <Border Width="165" Padding="12,8" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Background="White" Margin="0,0,10,0">
                        <DockPanel>
                            <TextBlock Text="전체" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TotalCount}" DockPanel.Dock="Right" Foreground="{StaticResource BrandBlue}" FontSize="18" FontWeight="Bold"/>
                        </DockPanel>
                    </Border>
                    <Border Width="165" Padding="12,8" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Background="White" Margin="0,0,10,0">
                        <DockPanel>
                            <TextBlock Text="자동 매칭" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding AutoMatchedCount}" DockPanel.Dock="Right" Foreground="#2E9A3A" FontSize="18" FontWeight="Bold"/>
                        </DockPanel>
                    </Border>
                    <Border Width="165" Padding="12,8" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Background="White" Margin="0,0,10,0">
                        <DockPanel>
                            <TextBlock Text="검토 필요" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ReviewNeededCount}" DockPanel.Dock="Right" Foreground="#FF8500" FontSize="18" FontWeight="Bold"/>
                        </DockPanel>
                    </Border>
                    <Border Width="165" Padding="12,8" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5" Background="White">
                        <DockPanel>
                            <TextBlock Text="미등록" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UnregisteredCount}" DockPanel.Dock="Right" Foreground="#E11D48" FontSize="18" FontWeight="Bold"/>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ProductRows}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="All"
                          BorderBrush="{StaticResource Line}"
                          BorderThickness="1"
                          RowHeight="34"
                          Background="White"
                          AlternatingRowBackground="#FAFCFF"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Margin="0,74,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Revit ID" Binding="{Binding RevitId}" Width="70"/>
                        <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="70"/>
                        <DataGridTextColumn Header="재료명" Binding="{Binding MaterialName}" Width="120"/>
                        <DataGridTextColumn Header="제조사" Binding="{Binding Manufacturer}" Width="105"/>
                        <DataGridTextColumn Header="인증제품명" Binding="{Binding CertifiedProduct}" Width="150"/>
                        <DataGridTextColumn Header="인증번호" Binding="{Binding CertificationNumber}" Width="95"/>
                        <DataGridTemplateColumn Header="매칭상태" Width="86">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding MatchStatusBackground}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding MatchStatus}" Foreground="{Binding MatchStatusForeground}" FontWeight="SemiBold" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="수량" Binding="{Binding Quantity}" Width="70"/>
                        <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="48"/>
                        <DataGridTextColumn Header="탄소발자국" Binding="{Binding CarbonFootprint}" Width="86"/>
                        <DataGridTemplateColumn Header="활용" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="GB" Style="{StaticResource SmallBadgeButton}" Visibility="{Binding UseGbVisibility}"/>
                                        <Button Content="CO2" Style="{StaticResource SmallBadgeButton}" Visibility="{Binding UseCarbonVisibility}"/>
                                        <Button Content="시각화" Style="{StaticResource SmallBadgeButton}" Visibility="{Binding UseVisualizationVisibility}"/>
                                        <Button Content="보고서" Style="{StaticResource SmallBadgeButton}" Visibility="{Binding UseReportVisibility}"/>
                                        <TextBlock Text="-" VerticalAlignment="Center" Foreground="#64748B" Visibility="{Binding EmptyUsageVisibility}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="매칭 검토" Style="{StaticResource OutlineButton}" Command="{Binding ReviewMatchCommand}"/>
                    <Button Grid.Column="2" Content="결과 색상 가시화" Style="{StaticResource OutlineButton}" Command="{Binding VisualizeCommand}"/>
                    <Button Grid.Column="4" Content="GB 평가 반영" Style="{StaticResource OutlineButton}" Command="{Binding ApplyGbCommand}"/>
                    <Button Grid.Column="6" Content="엑셀 보고서 출력" Style="{StaticResource OutlineButton}" Command="{Binding ExportExcelCommand}"/>
                </Grid>
            </Grid>

            <Border Grid.Column="4" Style="{StaticResource PanelBorder}">
                <StackPanel>
                    <TextBlock Text="활용 결과 요약" FontSize="15" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,12"/>

                    <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="친환경 제품 사용 현황" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="전체 자재" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding TotalCount}" HorizontalAlignment="Center" Foreground="{StaticResource BrandBlue}" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="인증 제품" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CertifiedProductCount}" HorizontalAlignment="Center" Foreground="{StaticResource BrandBlue}" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="미등록" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding UnregisteredCount}" HorizontalAlignment="Center" Foreground="{StaticResource BrandBlue}" FontSize="22" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="탄소발자국 요약" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,8"/>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="총합" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CarbonTotal}" DockPanel.Dock="Right" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </DockPanel>
                            <ProgressBar Height="7" Value="70" Maximum="100" Foreground="{StaticResource BrandBlue}" Background="#E8EEF6" Margin="0,0,0,10"/>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="평균" DockPanel.Dock="Left" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CarbonAverage}" DockPanel.Dock="Right" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </DockPanel>
                            <ProgressBar Height="7" Value="52" Maximum="100" Foreground="{StaticResource BrandBlue}" Background="#E8EEF6"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="GB 인증 활용 항목" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,8"/>
                            <TextBlock Text="✓ 친환경 자재 반영" Foreground="{StaticResource BrandBlue}" Margin="0,3"/>
                            <TextBlock Text="✓ 저탄소제품 반영" Foreground="{StaticResource BrandBlue}" Margin="0,3"/>
                            <TextBlock Text="✓ 환경성적표지 확인" Foreground="{StaticResource BrandBlue}" Margin="0,3"/>
                            <TextBlock Text="✓ 평가 근거 데이터 저장" Foreground="{StaticResource BrandBlue}" Margin="0,3"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="12">
                        <StackPanel>
                            <TextBlock Text="리포트 출력" FontWeight="Bold" Foreground="#0F2544" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="요약 보고서" Style="{StaticResource OutlineButton}" Command="{Binding SummaryReportCommand}"/>
                                <Button Grid.Column="2" Content="상세 보고서" Style="{StaticResource OutlineButton}" Command="{Binding DetailReportCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="104"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding LastMatchDate, StringFormat=마지막 매칭 실행: {0}}" VerticalAlignment="Center" Foreground="#64748B"/>
            <TextBlock Grid.Column="2" Text="{Binding StatusText, StringFormat=상태: {0}}" VerticalAlignment="Center" Foreground="{StaticResource BrandBlue}" FontWeight="SemiBold"/>
            <Button Grid.Column="4" Content="닫기" Style="{StaticResource PrimaryButton}" Click="OnClose"/>
        </Grid>
    </Grid>
</Window>
