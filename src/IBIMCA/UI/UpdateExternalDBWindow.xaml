<Window x:Class="IBIMCA.UI.UpdateExternalDBWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="외부 DB 갱신"
        Height="420" Width="860"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Margin="12,0,12,12" Height="380" VerticalAlignment="Bottom">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header row: tabs + right buttons -->
        <Grid Grid.Row="0" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="293*"/>
                <ColumnDefinition Width="59*"/>
                <ColumnDefinition Width="238*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tabs -->
            <TabControl Grid.Column="0"
            Grid.ColumnSpan="4"
            VerticalAlignment="Bottom"
            SelectedIndex="{Binding SelectedTabIndex}"
            SelectionChanged="TabControl_SelectionChanged" Height="20">

                <TabControl.Template>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Tab headers (NO border line) -->
                            <TabPanel Grid.Row="0"
                          IsItemsHost="True"
                          Margin="0,0,0,0" />

                            <!-- Tab content (still works even if you don't use content) -->
                            <Border Grid.Row="1"
                        BorderThickness="0"
                        Background="{TemplateBinding Background}">
                                <ContentPresenter ContentSource="SelectedContent"
                                      Margin="{TemplateBinding Padding}" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <TabItem Header="설계인증 기준"/>
                <TabItem Header="친환경 정보"/>
                <TabItem Header="기타 정보"/>
            </TabControl>

            <!-- Right buttons (파일 로드 / 내보내기 / icons) -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="파일 로드" Padding="14,6" Margin="0,0,8,0" Command="{Binding LoadAllCommand}"/>
                <Button Content="내보내기" Padding="14,6" Margin="0,0,12,0" Command="{Binding ExportAllCommand}"/>

                <Button Width="30" Height="28" Content="◀" Margin="0,0,6,0" ToolTip="뒤로"/>

                <Button Width="30" Height="28" Content="X" ToolTip="닫기" Click="OnClose"/>
            </StackPanel>
        </Grid>

        <!-- Content (layout: left 3, right 3) -->
        <Border Grid.Row="1" BorderBrush="#BFBFBF" Margin="0,10,0,10" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT column -->
                <StackPanel Grid.Column="0">
                    <GroupBox Header="BF인증 파일 로드" Margin="0,0,0,12">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding BfPath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="파일 경로"/>
                            <Button Grid.Column="1" Height="30" Margin="10,0,0,0"
                                    Content="....." Command="{Binding BrowseBfCommand}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="GB인증 파일 로드" Margin="0,0,0,12">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding GbPath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="파일 경로"/>
                            <Button Grid.Column="1" Height="30" Margin="10,0,0,0"
                                    Content="....." Command="{Binding BrowseGbCommand}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="CPTED인증 파일 로드">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding CptedPath, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="파일 경로"/>
                            <Button Grid.Column="1" Height="30" Margin="10,0,0,0"
                                    Content="....." Command="{Binding BrowseCptedCommand}"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <!-- RIGHT column -->
                <StackPanel Grid.Column="2">
                    <GroupBox Header="친환경 정보" Margin="0,0,0,12">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Eco1Path, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="파일 경로"/>
                            <Button Grid.Column="1" Height="30" Margin="10,0,0,0"
                                    Content="....." Command="{Binding BrowseEco1Command}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="친환경 정보" Margin="0,0,0,12">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Eco2Path, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="파일 경로"/>
                            <Button Grid.Column="1" Height="30" Margin="10,0,0,0"
                                    Content="....." Command="{Binding BrowseEco2Command}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="친환경 정보">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Height="30"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding Eco3Path, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="파일 경로"/>
                            <Button Grid.Column="1" Height="30" Margin="10,0,0,0"
                                    Content="....." Command="{Binding BrowseEco3Command}"/>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                       Foreground="#666" Text="{Binding StatusText}"/>

            <Button Grid.Column="1" Width="120" Height="38"
                    Content="완료"
                    Command="{Binding FinishCommand}"/>
        </Grid>
    </Grid>
</Window>