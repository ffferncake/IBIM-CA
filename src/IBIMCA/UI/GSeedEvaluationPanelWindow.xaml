<Window x:Class="IBIMCA.UI.GSeedEvaluationPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="녹색건축 인증제도 (G-SEED) 평가 패널"
        Height="620" Width="920"
        MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F7F9FC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F7F9FC"/>
        <SolidColorBrush x:Key="GridBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#D6E4F3"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#1F5A98"/>
        <SolidColorBrush x:Key="HeaderForegroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextBrush" Color="#10233D"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2D7DD2"/>

        <Style x:Key="DarkHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource HeaderForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="DarkCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEBFA"/>
                    <Setter Property="Foreground" Value="#10233D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="MinHeight" Value="22"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F2F7FD"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF4FF"/>
                </Trigger>
                <DataTrigger Binding="{Binding Level}" Value="0">
                    <Setter Property="Background" Value="#DCEBFA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#1F5A98"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="IconToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1F5A98"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="BottomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#8A8A8A"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8" Background="{StaticResource PanelBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock Text="녹색건축 인증제도 (G-SEED)"
                       Foreground="{StaticResource TextBrush}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBox Width="260"
                     Height="24"
                     Margin="10,0,0,0"
                     HorizontalAlignment="Right"
                     DockPanel.Dock="Right"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="검색"/>
        </DockPanel>

        <DataGrid x:Name="MainGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding VisibleRows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="{StaticResource GridLineBrush}"
                  VerticalGridLinesBrush="{StaticResource GridLineBrush}"
                  Background="{StaticResource GridBackgroundBrush}"
                  Foreground="{StaticResource TextBrush}"
                  BorderBrush="#7398C9"
                  BorderThickness="1"
                  RowHeaderWidth="0"
                  AlternationCount="2"
                  ColumnHeaderStyle="{StaticResource DarkHeaderStyle}"
                  CellStyle="{StaticResource DarkCellStyle}"
                  RowStyle="{StaticResource DarkRowStyle}"
                  IsReadOnly="False">

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="제목" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="{Binding IndentMargin}">
                                <Button Style="{StaticResource IconToggleButtonStyle}"
                                        Visibility="{Binding HasChildren, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Command="{Binding DataContext.ToggleExpandCommand, ElementName=MainGrid}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="{Binding ExpandGlyph}"/>
                                </Button>

                                <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{StaticResource TextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="배점" Binding="{Binding MaxScore}" Width="70" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="점수" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Score}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextBrush}"
                                       FontWeight="SemiBold"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}"
                                     HorizontalContentAlignment="Center"
                                     IsReadOnly="{Binding HasChildren}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="결과" Binding="{Binding Result}" Width="70" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result}" Value="PASS">
                                    <Setter Property="Foreground" Value="#138A36"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Result}" Value="FAIL">
                                    <Setter Property="Foreground" Value="#D12D2D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Result}" Value="N/A">
                                    <Setter Property="Foreground" Value="#6B7280"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="검토 상태" Width="90" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Ellipse Width="12" Height="12" Fill="#A8B8CC"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="#FFFFFF" BorderBrush="#D6E4F3" BorderThickness="1" Padding="6,3">
                    <TextBlock Text="{Binding StatusItems}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#FFFFFF" BorderBrush="#D6E4F3" BorderThickness="1" Padding="6,3" Margin="4,0,0,0">
                    <TextBlock Text="{Binding StatusScore}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#FFFFFF" BorderBrush="#D6E4F3" BorderThickness="1" Padding="6,3" Margin="4,0,0,0">
                    <TextBlock Text="{Binding StatusGrade}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="저장" Style="{StaticResource BottomButtonStyle}" Click="OnSave"/>
                <Button Content="닫기" Style="{StaticResource BottomButtonStyle}" Click="OnClose"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
