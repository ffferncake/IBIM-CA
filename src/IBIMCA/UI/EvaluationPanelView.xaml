<!-- UI/EvaluationPanelView.xaml -->
<UserControl x:Class="IBIMCA.UI.EvaluationPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:IBIMCA.UI">

    <Grid Margin="10" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header line -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="장애물 없는 생활환경 인증제도 건축물"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <TextBox Width="220"
                     Margin="10,0,0,0"
                     HorizontalAlignment="Right"
                     DockPanel.Dock="Right"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="검색"/>
        </DockPanel>

        <!-- Main table -->
        <DataGrid x:Name="MainGrid"
                  Grid.Row="1"
                  Background="White"
                  ItemsSource="{Binding VisibleRows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="False">

            <DataGrid.Resources>
                <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            </DataGrid.Resources>

            <DataGrid.Columns>

                <!-- 제목 -->
                <DataGridTemplateColumn Header="제목" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Margin="{Binding IndentMargin}">

                                <Button Width="18" Height="18" Padding="0" Margin="0,0,4,0"
                                        Visibility="{Binding HasChildren, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Command="{Binding DataContext.ToggleExpandCommand, ElementName=MainGrid}"
                                        CommandParameter="{Binding}">
                                    <TextBlock Text="{Binding ExpandGlyph}" />
                                </Button>

                                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="배점" Binding="{Binding MaxScore}" Width="70" IsReadOnly="True"/>
                <DataGridTextColumn Header="점수" Binding="{Binding Score}" Width="70"/>

                <DataGridTextColumn Header="결과" Binding="{Binding Result}" Width="90" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="Black"/>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Result}" Value="우수">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Result}" Value="적합">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Result}" Value="부적합">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>

                                <DataTrigger Binding="{Binding Result}" Value="N/A">
                                    <Setter Property="Foreground" Value="Gray"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Bottom status + buttons -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StatusBar Grid.Column="0">
                <StatusBarItem Content="{Binding StatusItems}" />
                <Separator/>
                <StatusBarItem Content="{Binding StatusScore}" />
                <Separator/>
                <StatusBarItem Content="{Binding StatusPercent}" />
                <Separator/>
                <StatusBarItem Content="{Binding StatusGrade}" />
            </StatusBar>

            <!-- NOTE: DockablePane(UserControl)에서는 Window의 Click 핸들러(OnSave/OnClose)가 없을 수 있어
                 일단 버튼은 남겨두되, 필요하면 Command로 바꾸는 걸 추천 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,0,0,0">
                <Button Content="저장" Width="90" Margin="0,0,8,0"/>
                <Button Content="닫기" Width="90"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>