<Window x:Class="IBIMCA.UI.StandardEvaluationSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="정성적 평가 설정"
        Height="640"
        Width="1040"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F7F9FC">
    <Window.Resources>
        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DarkGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="#F4F4F4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DarkGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="#3F3F3F"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="CptedGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1F5A98"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#174B82"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="CptedGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#D6E4F3"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEBFA"/>
                    <Setter Property="Foreground" Value="#0F2A44"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BlueGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F2F7FD"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF4FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEBFA"/>
                    <Setter Property="Foreground" Value="#0F2A44"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10" Background="#F7F9FC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="정성적 평가 설정"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#0F2A44"
                   Margin="0,0,0,10"/>

        <TabControl Grid.Row="1"
                    Background="#F7F9FC"
                    BorderBrush="#D6E4F3">
            <TabItem Header="BF">
                <DataGrid ItemsSource="{Binding BfItems}"
                          Margin="8"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          IsReadOnly="False"
                          RowHeight="34"
                          AlternationCount="2"
                          RowBackground="#FFFFFF"
                          AlternatingRowBackground="#F2F7FD"
                          BorderBrush="#D6E4F3"
                          HorizontalGridLinesBrush="#D6E4F3"
                          VerticalGridLinesBrush="#D6E4F3"
                          ColumnHeaderStyle="{StaticResource CptedGridHeaderStyle}"
                          CellStyle="{StaticResource CptedGridCellStyle}"
                          RowStyle="{StaticResource BlueGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="유형" Binding="{Binding Category}" Width="180" IsReadOnly="True"/>
                        <DataGridTextColumn Header="속성" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="적용" Binding="{Binding IsEnabled}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="G-SEED">
                <DataGrid ItemsSource="{Binding GSeedItems}"
                          Margin="8"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          RowHeight="34"
                          AlternationCount="2"
                          Background="#FFFFFF"
                          Foreground="#1E293B"
                          RowBackground="#FFFFFF"
                          AlternatingRowBackground="#F2F7FD"
                          BorderBrush="#D6E4F3"
                          HorizontalGridLinesBrush="#D6E4F3"
                          VerticalGridLinesBrush="#D6E4F3"
                          ColumnHeaderStyle="{StaticResource CptedGridHeaderStyle}"
                          CellStyle="{StaticResource CptedGridCellStyle}"
                          RowStyle="{StaticResource BlueGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="유형" Binding="{Binding Type}" Width="220" IsReadOnly="True"/>
                        <DataGridTextColumn Header="인증항목" Binding="{Binding CertificationItem}" Width="230" IsReadOnly="True"/>
                        <DataGridTextColumn Header="정보" Binding="{Binding Info}" Width="*" IsReadOnly="True"/>
                        <DataGridCheckBoxColumn Header="" Binding="{Binding IsEnabled}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="CPTED">
                <DataGrid ItemsSource="{Binding CptedItems}"
                          Margin="8"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          RowHeight="34"
                          AlternationCount="2"
                          RowBackground="#FFFFFF"
                          AlternatingRowBackground="#F2F7FD"
                          BorderBrush="#D6E4F3"
                          HorizontalGridLinesBrush="#D6E4F3"
                          VerticalGridLinesBrush="#D6E4F3"
                          ColumnHeaderStyle="{StaticResource CptedGridHeaderStyle}"
                          CellStyle="{StaticResource CptedGridCellStyle}"
                          RowStyle="{StaticResource BlueGridRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="115" IsReadOnly="True"/>
                        <DataGridTextColumn Header="인증제도" Binding="{Binding Certification}" Width="95" IsReadOnly="True"/>
                        <DataGridTextColumn Header="대분류" Binding="{Binding MajorCategory}" Width="140" IsReadOnly="True"/>
                        <DataGridTextColumn Header="인증항목(대표사항)" Binding="{Binding RepresentativeItem}" Width="*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="저장" Width="90" Margin="0,0,8,0" Click="OnSave"/>
            <Button Content="닫기" Width="90" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
