<Window x:Class="IBIMCA.UI.RunFullEvaluationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="전체 평가 실행"
        Height="650" Width="1040"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F7F9FC">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F7F9FC"/>
        <SolidColorBrush x:Key="GridBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#D6E4F3"/>
        <SolidColorBrush x:Key="HeaderBrush" Color="#1F5A98"/>
        <SolidColorBrush x:Key="TextBrush" Color="#10233D"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5B6B80"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2D7DD2"/>

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D6E4F3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#2D7DD2"/>
            <Setter Property="BorderBrush" Value="#1D63AC"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#B8CBE3"/>
            <Setter Property="Foreground" Value="#10233D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RangeHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="RangeCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEBFA"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RangeRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="MinHeight" Value="24"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F2F7FD"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF4FF"/>
                </Trigger>
                <DataTrigger Binding="{Binding Level}" Value="0">
                    <Setter Property="Background" Value="#D7E9FB"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Level}" Value="1">
                    <Setter Property="Background" Value="#E3F0FC"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1F5A98"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="전체 평가 실행"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="전체 실행"/>
            <TabItem Header="부분 실행" IsSelected="True">
                <Border Style="{StaticResource SectionBorderStyle}" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="390"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="인증 선택"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Certifications}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.SelectCertificationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Width="360"
                                                HorizontalAlignment="Left"
                                                HorizontalContentAlignment="Stretch"
                                                Padding="0"
                                                Margin="0,0,0,10"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Border BorderBrush="#D6E4F3"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Background="#FFFFFF"
                                                    Width="360"
                                                    Padding="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="48"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="40" Height="40" CornerRadius="4"
                                                            Background="#EAF4FF"
                                                            BorderBrush="#B8D7F6"
                                                            BorderThickness="1">
                                                        <TextBlock Text="{Binding Code}"
                                                                   Foreground="#1F5A98"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="10"
                                                                   TextAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="14"/>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   FontSize="12"
                                                                   Margin="0,4,0,0"/>
                                                    </StackPanel>

                                                    <CheckBox Grid.Column="2"
                                                              IsChecked="{Binding IsSelected}"
                                                              IsHitTestVisible="False"
                                                              VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}" Padding="12" Background="#F8FBFF">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectedCertificationText}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedItemCountText}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding RunModeText}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="평가 범위 선택"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <TextBox Grid.Row="1"
                                     Height="32"
                                     Margin="0,0,0,10"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="평가항목 검색"/>

                            <DataGrid x:Name="RangeGrid"
                                      Grid.Row="2"
                                      ItemsSource="{Binding VisibleRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      HorizontalGridLinesBrush="{StaticResource GridLineBrush}"
                                      VerticalGridLinesBrush="{StaticResource GridLineBrush}"
                                      Background="{StaticResource GridBackgroundBrush}"
                                      BorderBrush="#7398C9"
                                      BorderThickness="1"
                                      RowHeaderWidth="0"
                                      AlternationCount="2"
                                      ColumnHeaderStyle="{StaticResource RangeHeaderStyle}"
                                      CellStyle="{StaticResource RangeCellStyle}"
                                      RowStyle="{StaticResource RangeRowStyle}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="평가 항목" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="{Binding IndentMargin}">
                                                    <Button Style="{StaticResource IconToggleButtonStyle}"
                                                            Visibility="{Binding HasChildren, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            Command="{Binding DataContext.ToggleExpandCommand, ElementName=RangeGrid}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="{Binding ExpandGlyph}"/>
                                                    </Button>

                                                    <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Style="{StaticResource SectionBorderStyle}"
                Padding="12"
                Margin="0,10,0,10"
                Background="#F8FBFF">
            <TextBlock Text="{Binding SelectionPath}"
                       Foreground="{StaticResource TextBrush}"
                       FontWeight="SemiBold"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="선택 초기화"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ResetSelectionCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="미리보기"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="OnPreview"
                    Margin="0,0,8,0"/>
            <Button Content="닫기"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="OnClose"
                    Margin="0,0,8,0"/>
            <Button Content="평가 실행"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnRun"/>
        </StackPanel>
    </Grid>
</Window>
