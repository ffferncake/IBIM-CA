<Window x:Class="IBIMCA.UI.AutoDesignCorrectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설계 대안 추천 실행 옵션"
        Height="520" Width="760"
        MinHeight="500" MinWidth="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F8FC">

    <Window.Resources>
        <SolidColorBrush x:Key="BrandBlue" Color="#0B3A78"/>
        <SolidColorBrush x:Key="Line" Color="#D8E2F0"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F2544"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="InputBox" TargetType="Control">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,22"/>
        </Style>

        <Style x:Key="CertButton" TargetType="RadioButton">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="Foreground" Value="#0F2544"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C8D6E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0B3A78"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#0B3A78"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="불러오기" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Command="{Binding LoadOptionsCommand}"/>
                <Button Content="실행" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Command="{Binding RunRecommendationCommand}"/>
                <Button Content="◀" Style="{StaticResource IconButton}"/>
                <Button Content="X" Style="{StaticResource IconButton}" Click="OnClose"/>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource Line}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" SelectedIndex="0">
                    <TabItem Header="기본 설정"/>
                    <TabItem Header="추천 기준"/>
                    <TabItem Header="출력 옵션"/>
                </TabControl>

                <Grid Grid.Row="1" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="인증 체계" Style="{StaticResource FieldLabel}"/>
                        <UniformGrid Columns="3" Margin="0,0,0,24">
                            <RadioButton Content="BF" GroupName="CertificationSystem" IsChecked="True" Style="{StaticResource CertButton}"/>
                            <RadioButton Content="GB" GroupName="CertificationSystem" Style="{StaticResource CertButton}"/>
                            <RadioButton Content="CPTED" GroupName="CertificationSystem" Style="{StaticResource CertButton}"/>
                        </UniformGrid>

                        <TextBlock Text="평가 범위" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputBox}" SelectedIndex="0">
                            <ComboBoxItem Content="현재 활성 뷰"/>
                            <ComboBoxItem Content="전체 프로젝트"/>
                            <ComboBoxItem Content="선택 요소만"/>
                        </ComboBox>

                        <TextBlock Text="현재 등급" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="우수 (85.3점)"
                                 Foreground="{StaticResource BrandBlue}"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="목표 등급" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputBox}" SelectedIndex="0">
                            <ComboBoxItem Content="최우수 (90점 이상)"/>
                            <ComboBoxItem Content="우수 (80점 이상)"/>
                            <ComboBoxItem Content="일반 (70점 이상)"/>
                        </ComboBox>

                        <TextBlock Text="적용 방식" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource InputBox}" SelectedIndex="0">
                            <ComboBoxItem Content="검토 후 적용"/>
                            <ComboBoxItem Content="자동 적용"/>
                            <ComboBoxItem Content="추천안만 생성"/>
                        </ComboBox>

                        <TextBlock Text="추천 유형" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource InputBox}"
                                 Text="미달 / 감점 / 상위등급"
                                 VerticalContentAlignment="Center"
                                 Padding="12,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="8,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="옵션을 설정한 뒤 [실행]을 누르면 추천을 시작합니다."
                       VerticalAlignment="Center"
                       Foreground="#334155"/>
            <Button Grid.Column="1"
                    Content="완료"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnClose"/>
        </Grid>
    </Grid>
</Window>
