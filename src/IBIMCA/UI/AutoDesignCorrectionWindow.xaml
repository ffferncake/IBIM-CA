<Window x:Class="IBIMCA.UI.AutoDesignCorrectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설계 대안 수정 제안"
        Height="335" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#F3F3F3" Padding="10" BorderBrush="#BFBFBF" BorderThickness="1">
            <DockPanel>
                <TextBlock Text="설계 대안 수정 제안"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="28" Height="26" Margin="8,0,0,0" Content="◀" ToolTip="뒤로"/>
                    <Button Width="28" Height="26" Margin="6,0,0,0" Content="X" ToolTip="닫기" Click="OnClose"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Group 1 -->
        <GroupBox Grid.Row="1" Header="평가항목 검색" Margin="0,12,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Text="{Binding EvaluationItem, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="평가항목"/>

                <Button Grid.Column="1"
                        Height="30"
                        Margin="10,0,0,0"
                        Content="....."
                        Command="{Binding PickEvaluationItemCommand}"/>
            </Grid>
        </GroupBox>

        <!-- Group 2 -->
        <GroupBox Grid.Row="2" Header="추천 설계 대안" Margin="0,12,0,0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="30"
                         VerticalContentAlignment="Center"
                         Text="{Binding SuggestedFix, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="추천안"/>

                <Button Grid.Column="1"
                        Height="30"
                        Margin="10,0,0,0"
                        Content="....."
                        Command="{Binding GenerateSuggestionCommand}"/>
            </Grid>
        </GroupBox>

        <!-- Spacer row -->
        <Border Grid.Row="3"/>

        <!-- Bottom bar -->
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Width="44" Height="34"
                    Content="◀"
                    ToolTip="뒤로"/>

            <Button Grid.Column="2"
                    Width="110" Height="34"
                    Margin="0,0,10,0"
                    Content="내보내기"
                    Command="{Binding ExportCommand}"/>

            <Button Grid.Column="3"
                    Width="90" Height="34"
                    Content="완료"
                    Command="{Binding FinishCommand}"/>
        </Grid>
    </Grid>
</Window>