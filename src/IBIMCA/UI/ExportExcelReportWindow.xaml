<Window x:Class="IBIMCA.UI.ExportExcelReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="[9] 엑셀 보고서 출력"
        Height="760" Width="1180"
        MinHeight="700" MinWidth="1040"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F6F9FD">

    <Window.Resources>
        <SolidColorBrush x:Key="BrandBlue" Color="#0B3A78"/>
        <SolidColorBrush x:Key="DeepBlue" Color="#0B3A78"/>
        <SolidColorBrush x:Key="Line" Color="#D8E2F0"/>
        <SolidColorBrush x:Key="MutedText" Color="#64748B"/>
        <SolidColorBrush x:Key="ExcelGreen" Color="#168A45"/>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="22,0"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="{StaticResource DeepBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DeepBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StepBadge" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource BrandBlue}"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="PreviewTab" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="{StaticResource DeepBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DeepBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ActivePreviewTab" BasedOn="{StaticResource PreviewTab}" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DeepBlue}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DeepBlue}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="GradeCheck" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,18,18"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="74"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="132"/>
            <RowDefinition Height="64"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Border Width="58"
                    Height="58"
                    CornerRadius="4"
                    Background="{StaticResource ExcelGreen}"
                    DockPanel.Dock="Left"
                    Margin="0,0,22,0"
                    VerticalAlignment="Center">
                <TextBlock Text="X"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="엑셀 보고서 출력" FontSize="24" FontWeight="Bold" Foreground="#0B2342"/>
                <TextBlock Text="평가 결과를 선택한 조건에 따라 Excel 보고서로 생성합니다."
                           FontSize="13"
                           Foreground="#334155"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1.08*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <DockPanel Margin="0,0,0,14">
                            <Border Style="{StaticResource StepBadge}">
                                <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="설계인증 선택" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        </DockPanel>

                        <CheckBox Content="BF 인증" IsChecked="True" FontSize="17" Margin="44,0,0,12"/>
                        <CheckBox Content="GB 인증" IsChecked="True" FontSize="17" Margin="44,0,0,12"/>
                        <CheckBox Content="CPTED 인증" FontSize="17" Margin="44,0,0,20"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                    <Border Style="{StaticResource StepBadge}">
                                        <TextBlock Text="2" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="출력 범위 선택" FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                                </DockPanel>

                                <RadioButton Grid.Row="1" Content="전체 평가 결과 출력" IsChecked="True" FontSize="14" Margin="46,0,0,12"/>
                                <RadioButton Grid.Row="2" Content="선택 항목만 출력" FontSize="14" Margin="46,0,0,16"/>

                                <Border Grid.Row="3" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="4" Padding="10">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <CheckBox Content="▾  BF 인증" FontSize="14" Margin="0,0,0,8"/>
                                            <CheckBox Content="      매개시설" FontSize="14" Margin="18,0,0,8"/>
                                            <CheckBox Content="      내부시설" FontSize="14" Margin="18,0,0,8"/>
                                            <CheckBox Content="▾  GB 인증" FontSize="14" Margin="0,6,0,8"/>
                                            <CheckBox Content="      토지이용 및 교통" FontSize="14" Margin="18,0,0,8"/>
                                            <CheckBox Content="      에너지 및 환경오염" FontSize="14" Margin="18,0,0,8"/>
                                            <CheckBox Content="▾  CPTED 인증" FontSize="14" Margin="0,6,0,8"/>
                                            <CheckBox Content="      자연적 감시" FontSize="14" Margin="18,0,0,8"/>
                                            <CheckBox Content="      접근통제" FontSize="14" Margin="18,0,0,8"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                    <Border Style="{StaticResource StepBadge}">
                                        <TextBlock Text="3" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="등급 필터" FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                                </DockPanel>

                                <StackPanel Grid.Row="1" Margin="28,0,0,14">
                                    <RadioButton Content="전체 등급 출력" IsChecked="True" FontSize="14" Margin="0,0,0,12"/>
                                    <RadioButton Content="미흡 / 부적합 항목만 출력" FontSize="14" Margin="0,0,0,12"/>
                                    <RadioButton Content="선택 등급만 출력" FontSize="14"/>
                                </StackPanel>

                                <Border Grid.Row="2" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="4" Padding="18">
                                    <UniformGrid Columns="2">
                                        <CheckBox Content="●  최우수" Foreground="#159447" Style="{StaticResource GradeCheck}"/>
                                        <CheckBox Content="●  우수" Foreground="#65C849" Style="{StaticResource GradeCheck}"/>
                                        <CheckBox Content="●  일반" Foreground="#F8BE1A" Style="{StaticResource GradeCheck}"/>
                                        <CheckBox Content="●  미흡" Foreground="#F97316" Style="{StaticResource GradeCheck}"/>
                                        <CheckBox Content="●  부적합" Foreground="#E33434" Style="{StaticResource GradeCheck}"/>
                                        <CheckBox Content="●  검토 필요" Foreground="#8B8F98" Style="{StaticResource GradeCheck}"/>
                                    </UniformGrid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="132"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,18">
                        <TextBlock Text="▤" FontSize="28" Foreground="#64748B" Margin="0,0,16,0"/>
                        <TextBlock Text="출력 미리보기" FontSize="19" FontWeight="Bold" VerticalAlignment="Center"/>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <UniformGrid Grid.Column="0" Rows="2">
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5,5,0,0" Padding="16">
                                <TextBlock Text="🛡  선택 인증: BF, GB" FontSize="15" VerticalAlignment="Center"/>
                            </Border>
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="1,0,1,1" CornerRadius="0,0,5,5" Padding="16">
                                <TextBlock Text="▽  등급 필터: 전체 등급" FontSize="15" VerticalAlignment="Center"/>
                            </Border>
                        </UniformGrid>
                        <UniformGrid Grid.Column="2" Rows="2">
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="5,5,0,0" Padding="16">
                                <TextBlock Text="☷  출력 범위: 전체 평가 결과" FontSize="15" VerticalAlignment="Center"/>
                            </Border>
                            <Border BorderBrush="{StaticResource Line}" BorderThickness="1,0,1,1" CornerRadius="0,0,5,5" Padding="16">
                                <TextBlock FontSize="15" VerticalAlignment="Center">
                                    <Run Text="▦  예상 시트 수: "/><Run Text="5" Foreground="{StaticResource BrandBlue}" FontWeight="Bold"/>
                                </TextBlock>
                            </Border>
                        </UniformGrid>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="보고서 요약" Style="{StaticResource ActivePreviewTab}"/>
                        <Button Content="상세 평가 결과" Style="{StaticResource PreviewTab}"/>
                        <Button Content="미흡/부적합 항목" Style="{StaticResource PreviewTab}"/>
                        <Button Content="Revit 객체 목록" Style="{StaticResource PreviewTab}"/>
                        <Button Content="출력 조건 정보" Style="{StaticResource PreviewTab}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="3"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              BorderBrush="{StaticResource Line}"
                              BorderThickness="1"
                              RowHeight="52"
                              ItemsSource="{Binding PreviewRows}"
                              Margin="0,0,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="인증구분" Binding="{Binding Certification}" Width="*"/>
                            <DataGridTextColumn Header="평가항목" Binding="{Binding Item}" Width="1.5*"/>
                            <DataGridTextColumn Header="결과" Binding="{Binding Result}" Width="1.25*"/>
                            <DataGridTextColumn Header="등급" Binding="{Binding Grade}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="38"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <Border Style="{StaticResource StepBadge}">
                        <TextBlock Text="4" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="저장 옵션" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </DockPanel>
                <Grid Grid.Row="1" Margin="38,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="560"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="파일명:" VerticalAlignment="Center" FontSize="14"/>
                    <TextBox Grid.Column="1" Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="12,0"/>
                </Grid>
                <Grid Grid.Row="3" Margin="38,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="560"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="저장 위치:" VerticalAlignment="Center" FontSize="14"/>
                    <TextBox Grid.Column="1" Text="{Binding SaveLocation, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="12,0"/>
                    <Button Grid.Column="2" Content="찾아보기" Style="{StaticResource OutlineButton}" Margin="10,0,0,0" Command="{Binding BrowseSaveLocationCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="미리보기" Style="{StaticResource OutlineButton}" Command="{Binding PreviewCommand}"/>
            <Button Grid.Column="3" Content="취소" Style="{StaticResource OutlineButton}" Click="OnClose"/>
            <Button Grid.Column="5" Content="▣  엑셀 출력" Style="{StaticResource PrimaryButton}" Command="{Binding FinishCommand}"/>
        </Grid>
    </Grid>
</Window>
