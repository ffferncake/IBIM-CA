<Window x:Class="IBIMCA.UI.AIAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AIBIM Chat"
        Height="560" Width="760"
        MinHeight="500" MinWidth="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F8FC"
        FontFamily="Malgun Gothic"
        FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="BrandBlue" Color="#0B3A78"/>
        <SolidColorBrush x:Key="PanelLine" Color="#D8E2F0"/>

        <Style x:Key="TopTabButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="106"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0F2A4D"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D5DFEC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F6FF"/>
                                <Setter Property="BorderBrush" Value="#86B7F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveTopTabButton" BasedOn="{StaticResource TopTabButton}" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0B3A78"/>
            <Setter Property="BorderBrush" Value="#0B3A78"/>
        </Style>

        <Style x:Key="SideButton" TargetType="Button">
            <Setter Property="Height" Value="78"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#174F93"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="13,5"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0B3A78"/>
            <Setter Property="Background" Value="#F3F8FF"/>
            <Setter Property="BorderBrush" Value="#BFD8F7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F5F8FC"
                BorderBrush="#D9E3F0"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="22,0,22,0">
                <TextBlock Text="AIBIM Chat"
                           VerticalAlignment="Center"
                           Foreground="#0B2342"
                           FontSize="24"
                           FontWeight="Bold"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="BF" Style="{StaticResource ActiveTopTabButton}" Command="{Binding SelectDomainCommand}" CommandParameter="BF"/>
                    <Button Content="G-SEED" Style="{StaticResource TopTabButton}" Command="{Binding SelectDomainCommand}" CommandParameter="G-SEED"/>
                    <Button Content="CPTED" Style="{StaticResource TopTabButton}" Command="{Binding SelectDomainCommand}" CommandParameter="CPTED"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="84"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BrandBlue}">
                <StackPanel Margin="0,12,0,0">
                    <Button Style="{StaticResource SideButton}">
                        <StackPanel>
                            <TextBlock Text="▤" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="기준" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SideButton}">
                        <StackPanel>
                            <TextBlock Text="▥" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="결과" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SideButton}">
                        <StackPanel>
                            <TextBlock Text="□" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="가이드" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SideButton}">
                        <StackPanel>
                            <TextBlock Text="▣" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="보고서" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Background="#F8FBFF">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="58"/>
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="MessageScrollViewer"
                              Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              Padding="22,16,22,10">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="34" Height="34"
                                            CornerRadius="17"
                                            BorderBrush="#C5DAF6"
                                            BorderThickness="1"
                                            Background="White"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding BotIconVisibility}">
                                        <TextBlock Text="AI"
                                                   Foreground="#0B3A78"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Padding="14,10"
                                            CornerRadius="8"
                                            MaxWidth="470"
                                            HorizontalAlignment="{Binding BubbleAlign}"
                                            Background="{Binding BubbleBackground}"
                                            BorderBrush="{Binding BubbleBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,6"
                                                       Visibility="{Binding HeaderVisibility}">
                                                <TextBlock Text="{Binding SenderLabel}"
                                                           DockPanel.Dock="Left"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="#0B3A78"/>
                                                <TextBlock Text="{Binding TimeText}"
                                                           DockPanel.Dock="Right"
                                                           Foreground="#6B7C92"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Text}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="20"
                                                       FontSize="13"
                                                       Foreground="#13233A"/>
                                            <TextBlock Text="{Binding TimeText}"
                                                       Visibility="{Binding UserTimeVisibility}"
                                                       FontSize="11"
                                                       Foreground="#6B7C92"
                                                       HorizontalAlignment="Right"
                                                       Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Width="34" Height="34"
                                            CornerRadius="17"
                                            BorderBrush="#B4D1F7"
                                            BorderThickness="1"
                                            Background="#E9F3FF"
                                            VerticalAlignment="Top"
                                            Visibility="{Binding UserIconVisibility}">
                                        <TextBlock Text="●"
                                                   Foreground="#155AA8"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                    <WrapPanel Grid.Row="1" Margin="30,2,22,2">
                    <Button Content="BF 주출입구 보행로 기준"
                            Style="{StaticResource QuickButton}"
                            Command="{Binding AskPresetCommand}"
                            CommandParameter="BF 주출입구 보행로 기준 알려줘"/>
                    <Button Content="G-SEED 에너지 성능"
                            Style="{StaticResource QuickButton}"
                            Command="{Binding AskPresetCommand}"
                            CommandParameter="G-SEED 에너지 성능 기준 알려줘"/>
                    <Button Content="CPTED 출입구 가시성"
                            Style="{StaticResource QuickButton}"
                            Command="{Binding AskPresetCommand}"
                            CommandParameter="CPTED 출입구 가시성 기준 알려줘"/>
                    <Button Content="결과 요약"
                            Style="{StaticResource QuickButton}"
                            Command="{Binding AskPresetCommand}"
                            CommandParameter="현재 평가 결과 요약해줘"/>
                </WrapPanel>

                <Border Grid.Row="2"
                        Margin="16,8,16,14"
                        Background="White"
                        BorderBrush="{StaticResource PanelLine}"
                        BorderThickness="1"
                        CornerRadius="7">
                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <TextBox x:Name="InputBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"
                                     Padding="2,0"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="OnInputKeyDown"/>
                            <TextBlock Text="메시지를 입력하세요..."
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Foreground="#9AA8BA"
                                       FontSize="13"
                                       Margin="3,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=InputBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="1"
                                Width="38" Height="38"
                                Background="{StaticResource BrandBlue}"
                                Foreground="White"
                                BorderBrush="{StaticResource BrandBlue}"
                                BorderThickness="0"
                                FontSize="18"
                                Content="▶"
                                Command="{Binding SendCommand}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
