<Window x:Class="IBIMCA.UI.AIAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI 챗봇 어시스턴트"
        Height="620" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="12" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="AI 챗봇 어시스턴트" FontWeight="SemiBold" FontSize="14"/>
                    <TextBlock Text="지능형 설계인증 지원" Foreground="#6B7280" FontSize="12"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="대화 초기화" Padding="10,6" Margin="0,0,8,0"
                            Command="{Binding ClearCommand}"/>
                    <Button Content="예시 대화" Padding="10,6"
                            Command="{Binding SeedDemoCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Chat area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Bubble -->
                            <Border Padding="10"
                                    CornerRadius="12"
                                    MaxWidth="320"
                                    HorizontalAlignment="{Binding BubbleAlign}"
                                    Background="{Binding BubbleBackground}"
                                    BorderBrush="{Binding BubbleBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding SenderLabel}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#374151"
                                               Margin="0,0,0,4"
                                               Visibility="{Binding SenderLabelVisibility}"/>
                                    <TextBlock Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               FontSize="13"
                                               Foreground="#111827"/>
                                    <TextBlock Text="{Binding TimeText}"
                                               FontSize="10"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Right"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input bar -->
        <Border Grid.Row="2" Background="White" Padding="10" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="OnInputKeyDown"
                         ToolTip="메시지를 입력하세요..."
                         />

                <Button Grid.Column="1"
                        Height="36"
                        Margin="8,0,0,0"
                        Padding="14,0"
                        Content="Send"
                        Command="{Binding SendCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>