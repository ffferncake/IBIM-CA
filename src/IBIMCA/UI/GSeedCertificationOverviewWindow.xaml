<Window x:Class="IBIMCA.UI.GSeedCertificationOverviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Intelligent BIM - Certification Automation"
        Height="600"
        Width="960"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F7FAF8"
        FontFamily="Malgun Gothic">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9E5DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1F2F27"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#24364B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF8F1"/>
                    <Setter Property="BorderBrush" Value="#B7DCC2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#EAF7EE"/>
            <Setter Property="BorderBrush" Value="#A8DDB6"/>
            <Setter Property="Foreground" Value="#14863A"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#8FB4E8"/>
            <Setter Property="Foreground" Value="#1C579B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5FAFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TinyHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F1F5F2"/>
            <Setter Property="BorderBrush" Value="#D6E1DB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="TinyCellStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2EAE5"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="EvaluationTileStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7FCF8"/>
            <Setter Property="BorderBrush" Value="#DDEEE2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="EvaluationIconStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="32"/>
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#149244"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="EvaluationLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#263548"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="GuideLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#14863A"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="GuideTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="18"/>
        </Style>

        <Style x:Key="ParameterKeyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style x:Key="ParameterTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F4F93" BorderThickness="0">
            <TextBlock Text="Intelligent BIM - Certification Automation"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10,0"
                       FontSize="12"
                       FontWeight="SemiBold"/>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FBFDFB"
                    BorderBrush="#DCE8DF"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="14,14,10,12">
                        <TextBlock Text="◉"
                                   FontSize="28"
                                   Foreground="#149244"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="녹색건축 인증제도"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"/>
                        <TextBlock Text="(G-SEED)"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Button Style="{StaticResource SelectedNavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⌂" FontSize="16" Width="24"/>
                                <TextBlock Text="인증 개요"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnGuideLink">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔗" FontSize="14" Width="24"/>
                                <TextBlock Text="설계인증 가이드 링크"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnBimModelGuide">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="□" FontSize="16" Width="24"/>
                                <TextBlock Text="BIM 모델링 가이드"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnEvaluationItems">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="☷" FontSize="16" Width="24"/>
                                <TextBlock Text="주요 평가영역"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Click="OnLinkedData">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▤" FontSize="16" Width="24"/>
                                <TextBlock Text="개발 연계 데이터"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="12,0,12,12">
                        <Separator Margin="0,0,0,8"/>
                        <Button Style="{StaticResource NavButtonStyle}" Height="30" Click="OnSettings">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" Width="24"/>
                                <TextBlock Text="설정"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="버전 1.0.0"
                                   Foreground="#7A8698"
                                   FontSize="11"
                                   Margin="10,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="14,12,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="녹색건축 인증제도 (G-SEED)"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           Margin="0,0,0,10"/>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="38"
                                Height="38"
                                CornerRadius="19"
                                Background="#149244"
                                BorderThickness="0"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Center">
                            <TextBlock Text="◒"
                                       FontSize="24"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="제도 소개" FontWeight="Bold" Foreground="#14863A" Margin="0,0,0,8"/>
                            <TextBlock Text="목적" FontWeight="Bold" Foreground="#14863A" Margin="0,0,0,8"/>
                            <TextBlock Text="대상 건축물" FontWeight="Bold" Foreground="#14863A" Margin="0,0,0,8"/>
                            <TextBlock Text="활용" FontWeight="Bold" Foreground="#14863A"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="녹색건축의 조성과 건축물의 성능향상을 도모하고, 지속가능한 환경을 구현하기 위한 국가 공인 녹색건축 인증제도입니다."
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock Text="에너지 절감, 환경오염 저감, 쾌적한 실내환경, 자원절약, 생태보전 등을 통해 친환경 건축물의 가치를 높입니다."
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock Text="신축, 기존 건축물, 리모델링, 그린리모델링 등 연면적 3,000㎡ 이상 건축물과 관련 기준에 따른 대상 건축물"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock Text="설계 단계부터 녹색건축 성능을 정량화하여 인증 등급 확보, 성능 검토 및 개선 방향 도출을 지원합니다."
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource ActionButtonStyle}" Click="OnOpenWebsite">
                            <TextBlock Text="🌐  공식 안내" TextAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource ActionButtonStyle}" BorderBrush="#E49D9D" Foreground="#B63535" Click="OnOpenPdf">
                            <TextBlock Text="▣  평가기준 PDF" TextAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource ActionButtonStyle}" BorderBrush="#92C79A" Foreground="#2E7D3F" Click="OnChecklist">
                            <TextBlock Text="☑  체크리스트" TextAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="3" Style="{StaticResource ActionButtonStyle}" BorderBrush="#B99AE8" Foreground="#6A3DB3" Margin="0" Click="OnFaq">
                            <TextBlock Text="?  FAQ" TextAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.12*"/>
                            <ColumnDefinition Width="1.55*"/>
                            <ColumnDefinition Width="1.02*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="주요 평가영역" Style="{StaticResource SectionTitleStyle}"/>
                                <UniformGrid Columns="2" Rows="4" Margin="0,2,0,0">
                                    <Border Style="{StaticResource EvaluationTileStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="♧" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="토지이용 및 교통" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource EvaluationTileStyle}" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="↯" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="에너지 및 환경오염" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource EvaluationTileStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="◇" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="재료 및 자원" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource EvaluationTileStyle}" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="♢" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="물순환관리" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource EvaluationTileStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⌘" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="유지관리" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource EvaluationTileStyle}" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="♣" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="생태환경" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource EvaluationTileStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⌂" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="실내환경" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource EvaluationTileStyle}" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="☆" Style="{StaticResource EvaluationIconStyle}"/>
                                            <TextBlock Text="혁신 설계" Style="{StaticResource EvaluationLabelStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="BIM 모델링 가이드" Style="{StaticResource SectionTitleStyle}"/>
                                <Grid Margin="0,1,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="외피 성능" Style="{StaticResource GuideLabelStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="벽, 지붕, 바닥의 단열재, 열관류율, 기밀성 정보를 정확히 입력합니다." Style="{StaticResource GuideTextStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="창호 정보" Style="{StaticResource GuideLabelStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="유리 사양, 프레임, U값, SHGC를 파라미터로 관리합니다." Style="{StaticResource GuideTextStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="재료 속성" Style="{StaticResource GuideLabelStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="재활용 함량, 저탄소/친환경 인증 등 재료 특성을 입력합니다." Style="{StaticResource GuideTextStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="면적/용적" Style="{StaticResource GuideLabelStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="연면적, 대지면적, 녹지면적, 조경면적을 산출합니다." Style="{StaticResource GuideTextStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="설비 데이터" Style="{StaticResource GuideLabelStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="기기 효율, 제어방식, 환기량 등 설비 성능 정보를 입력합니다." Style="{StaticResource GuideTextStyle}" Margin="0,0,0,7"/>
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="에너지 해석 연계" Style="{StaticResource GuideLabelStyle}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="에너지 해석 결과를 Revit 파라미터와 연계하여 관리합니다." Style="{StaticResource GuideTextStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="필수 파라미터" Style="{StaticResource SectionTitleStyle}"/>
                                <Grid Margin="0,1,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*"/>
                                        <ColumnDefinition Width="1.7*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TinyHeaderStyle}">
                                        <TextBlock Text="필드 키" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource TinyHeaderStyle}">
                                        <TextBlock Text="설명" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="GrossArea" Style="{StaticResource ParameterKeyStyle}"/>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="건축물 연면적 (㎡)" Style="{StaticResource ParameterTextStyle}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="WindowUValue" Style="{StaticResource ParameterKeyStyle}"/>
                                    </Border>
                                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="창호 열관류율 (W/㎡·K)" Style="{StaticResource ParameterTextStyle}"/>
                                    </Border>
                                    <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="SHGC" Style="{StaticResource ParameterKeyStyle}"/>
                                    </Border>
                                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="창호 일사취득계수" Style="{StaticResource ParameterTextStyle}"/>
                                    </Border>
                                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="MaterialCode" Style="{StaticResource ParameterKeyStyle}"/>
                                    </Border>
                                    <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="주요 재료 코드" Style="{StaticResource ParameterTextStyle}"/>
                                    </Border>
                                    <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="LightingDensity" Style="{StaticResource ParameterKeyStyle}"/>
                                    </Border>
                                    <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="조명 밀도 (W/㎡)" Style="{StaticResource ParameterTextStyle}"/>
                                    </Border>
                                    <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="HVACType" Style="{StaticResource ParameterKeyStyle}"/>
                                    </Border>
                                    <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource TinyCellStyle}">
                                        <TextBlock Text="냉난방 시스템 유형" Style="{StaticResource ParameterTextStyle}"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0,10,0,0" Padding="10">
                        <StackPanel>
                            <TextBlock Text="개발 연계 데이터 항목" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*"/>
                                    <ColumnDefinition Width="1.05*"/>
                                    <ColumnDefinition Width="1.55*"/>
                                    <ColumnDefinition Width="1.25*"/>
                                    <ColumnDefinition Width="0.9*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource TinyHeaderStyle}"><TextBlock Text="FieldKey" FontWeight="Bold"/></Border>
